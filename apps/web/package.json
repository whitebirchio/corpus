{
  "name": "corpus-web",
  "version": "0.1.0",
  "private": true,
  "description": "Corpus PWA — React client + Hono REST adapter in one Cloudflare Worker.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc -p tsconfig.app.json && tsc -p tsconfig.worker.json && tsc -p tsconfig.node.json",
    "test": "vitest run",
    "build": "vite build",
    "dev": "npm run build && wrangler dev",
    "dev:ui": "vite",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@corpus/core": "*",
    "@neondatabase/serverless": "^1.1.0",
    "barcode-detector": "^3.2.1",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.0.0",
    "zod": "^4.4.3",
    "zxing-wasm": "3.1.1"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  }
}
