{
  "name": "@corpus/core",
  "version": "0.1.0",
  "private": true,
  "description": "Corpus domain core: schema, validation, units, repositories. No MCP/HTTP dependencies.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/db/schema.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@neondatabase/serverless": "^1.1.0",
    "@types/node": "^26.1.0",
    "drizzle-kit": "^0.31.10",
    "pg": "^8.22.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
